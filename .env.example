# Programmatic SEO build env vars.
#
# Local development: leave SUPABASE_URL/SUPABASE_SERVICE_ROLE_KEY unset and
# set USE_MOCK_DATA=1 to render against src/fixtures/names-mock.json.
#
# Vercel production: set both SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY in
# the Vercel project settings → Environment Variables. Both are server-side
# only; they never reach the browser because Astro generates static HTML.
#
# Never commit the actual .env file. The service role key bypasses RLS and
# must be guarded like a production database password.

# Local dev mode
USE_MOCK_DATA=1

# Real Supabase connection (uncomment + populate for live build)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Build size limit (number of names to render — defaults to all rows)
# Use BUILD_LIMIT=100 for the test batch in Phase 2.
# BUILD_LIMIT=100
